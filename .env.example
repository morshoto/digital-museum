# Copy this file to .env for a visual-only Diffusers installation:
#   cp .env.example .env
#
# Values already exported by the calling shell take precedence over this file.
# The lifecycle scripts load literal KEY=value assignments; shell expansion and
# command substitution are intentionally not supported.

HF_HUB_DISABLE_XET=1
EVOLVING_BACKEND=diffusers
EVOLVING_MODEL_ID=stabilityai/sdxl-turbo
EVOLVING_VISUAL_HOST=127.0.0.1
EVOLVING_VISUAL_PORT=8891
EVOLVING_REQUIRE_MUSIC=0
EVOLVING_GENERATION_INTERVAL=5
EVOLVING_PREVENT_SLEEP=1
# EVOLVING_ORIGINAL_IMAGE=/absolute/path/to/another-image.png
